DATABASE_URL="postgresql://postgres:postgres@localhost:5432/basic_website_cms_admin?schema=public"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-random-secret-string"
GOOGLE_OAUTH_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_OAUTH_CLIENT_SECRET="replace-with-google-oauth-client-secret"
# Required for public website attachment uploads through Vercel Blob.
# Pull from Vercel after connecting a Blob store: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN="replace-with-vercel-blob-read-write-token"
# Public site origin used for preview links in the admin UI.
NEXT_PUBLIC_SITE_URL="https://www.example.com"
SITE_REVALIDATE_URL="https://www.example.com/api/revalidate"
SITE_REVALIDATE_SECRET="replace-with-shared-revalidation-secret"
